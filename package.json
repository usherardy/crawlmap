    "cors": "^2.8.6",
    "dagre": "^0.8.5",
    "express": "^5.2.1",
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
