{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "routes": [
    { "src": "/api/health", "dest": "/api/health.ts" },
    { "src": "/api/crawl", "dest": "/api/crawl.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/crawl.ts": { "maxDuration": 60 }
  }
}
